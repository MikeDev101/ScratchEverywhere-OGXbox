# Scratch Everywhere! on the Original Xbox

#---------------------------------------------------------------------------------
.SUFFIXES: 
#---------------------------------------------------------------------------------

# Ensure the NXDK path is set
ifeq ($(strip $(NXDK_DIR)),)
$(error "Please set the NXDK path in your environment. export NXDK_DIR=<path to>nxdk")
endif

# Ensure nxdk-cxx is in your path and executable
ifeq ($(shell command -v nxdk-cxx 2> /dev/null),)
$(error "nxdk-cxx not found in PATH. You might need to add nxdk/bin to your PATH.")
endif

#---------------------------------------------------------------------------------
XBE_TITLE   :=  scratch-xbox
GEN_XISO    :=  $(XBE_TITLE).iso

# Define Sources Directories (excluding minizip for now, we handle it manually below)
SOURCES     :=  source source/scratch source/scratch/blocks source/scratch/menus source/sdl source/sdl/audio source/utils include/nlohmann source/SDL2_gfx
INCLUDES    :=  include source/scratch source/scratch/blocks source/scratch/menus source/sdl source/sdl/audio source/utils include/nlohmann source/minizip-ng source/SDL2_gfx

INCLUDE_FLAGS   :=  $(foreach dir,$(INCLUDES),-I$(dir))

# Add -DHAVE_ZLIB and -DZLIB_COMPAT so minizip uses system zlib.h
CFLAGS    := $(INCLUDE_FLAGS) -DSDL_BUILD -D__XBOX__ -D_XBOX -DHAVE_ZLIB -DZLIB_COMPAT -D_WIN32
# Use -fno-exceptions to prevent linker errors
CXXFLAGS  := $(CFLAGS) -std=c++17 -fexceptions

# --- Source Collection ---

# 1. Grab standard sources (using wildcards is fine for your own code)
SRC_CPP     :=  $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.cpp))
SRC_C       :=  $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.c))

# 2. Explicitly list Minizip-NG files (No ghosts, no Apple crypto, no Win32)
MINIZIP_DIR := source/minizip-ng
MINIZIP_SRCS := \
    $(MINIZIP_DIR)/mz_zip.c \
    $(MINIZIP_DIR)/mz_zip_rw.c \
    $(MINIZIP_DIR)/mz_strm.c \
    $(MINIZIP_DIR)/mz_strm_mem.c \
    $(MINIZIP_DIR)/mz_strm_buf.c \
    $(MINIZIP_DIR)/mz_strm_split.c \
    $(MINIZIP_DIR)/mz_strm_zlib.c \
    $(MINIZIP_DIR)/mz_strm_pkcrypt.c \
    $(MINIZIP_DIR)/mz_os.c \
    $(MINIZIP_DIR)/mz_os_win32.c \
    $(MINIZIP_DIR)/mz_strm_os_win32.c

# Combine everything
SRCS        :=  $(SRC_CPP) $(SRC_C) $(MINIZIP_SRCS)

NXDK_SDL    :=  y
NXDK_CXX    :=  y

include $(NXDK_DIR)/Makefile