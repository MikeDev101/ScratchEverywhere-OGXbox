# Scratch Everywhere! on the Original Xbox
#
# Makefile template based on the original feat/og-xbox-support PR [https://github.com/ScratchEverywhere/ScratchEverywhere/pull/276]
# NOT READY FOR USE YET, THERE WILL BE VERY ANGRY DUCKS

#---------------------------------------------------------------------------------
.SUFFIXES: 
#---------------------------------------------------------------------------------

# Ensure the NXDK path is set
ifeq ($(strip $(NXDK_DIR)),)
$(error "Please set the NXDK path in your environment. export NXDK_DIR=<path to>nxdk")
endif

# Ensure nxdk-cxx is in your path and executable
ifeq ($(shell command -v nxdk-cxx 2> /dev/null),)
$(error "nxdk-cxx not found in PATH. You might need to add nxdk/bin to your PATH.")
endif

#---------------------------------------------------------------------------------
XBE_TITLE   :=  scratch-xbox
GEN_XISO    :=  $(XBE_TITLE).iso
SOURCES     :=  source source/scratch source/scratch/blocks source/scratch/menus source/sdl source/sdl/audio source/utils source/minizip-ng include/nlohmann source/miniz
INCLUDES    :=  include source/scratch source/scratch/blocks source/scratch/menus source/sdl source/sdl/audio source/utils source/minizip-ng include/nlohmann source/miniz
#---------------------------------------------------------------------------------

# Updated paths from the original feat/og-xbox-support
# 1. Removed: include/miniz
# 2. Added: source/utils (for our new C++ wrapper)
# 3. Added: include/minizip-ng

INCLUDE_FLAGS   :=  $(foreach dir,$(INCLUDES),-I$(dir))
CFLAGS          :=  $(INCLUDE_FLAGS) -DSDL_BUILD -D__XBOX__ -D_XBOX
CXXFLAGS        :=  $(CFLAGS) -std=c++17 -fexceptions

SRC_CPP     :=  $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.cpp))
SRC_C       :=  $(foreach dir,$(SOURCES),$(wildcard $(dir)/*.c))
SRCS        :=  $(SRC_CPP) $(SRC_C)

NXDK_SDL    :=  y
NXDK_CXX    :=  y

include $(NXDK_DIR)/Makefile